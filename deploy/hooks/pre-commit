#!/usr/bin/env bash
#
# VaultMesh pre-commit hook.
# Refuses commits that contain secrets or files outside the vault structure.
#
# Bypass in genuine emergencies: git commit --no-verify
# (but check FIRST what was blocked — there's usually a real reason)

set -eu

# Exit codes: 0 = OK, 1 = REJECT

RED="$(printf '\033[0;31m')"
YELLOW="$(printf '\033[0;33m')"
GREEN="$(printf '\033[0;32m')"
NC="$(printf '\033[0m')"

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACM)"

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

ERRORS=0
WARNINGS=0

# ============================================================
# RULE 1: dangerous file names
# ============================================================
while IFS= read -r file; do
  case "$file" in
    *.env|*/.env|\
    */config/app.php|*/config/database.php|*/config/database.default.php|\
    */config/database.yml|*/config/secrets.yml|\
    */settings.local.py|*/local_settings.py|\
    .htpasswd|*/.htpasswd|\
    id_rsa|*/id_rsa|id_ed25519|*/id_ed25519|*.pem|*.key|*.p12|\
    *.sql|*.dump|*.sql.gz)
      printf "${RED}X REJECT${NC}: forbidden file: %s\n" "$file"
      ERRORS=$((ERRORS + 1))
      ;;
  esac
done <<EOF
$STAGED_FILES
EOF

# ============================================================
# RULE 2: suspicious content in new/modified files
# ============================================================
PATTERNS='(password|passwd|pwd|api[_-]?key|secret[_-]?key|access[_-]?key|private[_-]?key|auth[_-]?token|bearer[_-]?token)\s*[:=]\s*["\x27]?[A-Za-z0-9/+=_\-]{12,}'

while IFS= read -r file; do
  # Skip binaries and missing files
  [ -f "$file" ] || continue
  case "$(file --mime-type -b "$file" 2>/dev/null || echo text)" in
    text/*|application/json|application/xml|inode/x-empty) ;;
    *) continue ;;
  esac

  # MySQL/Postgres connection string with password
  if git show ":$file" 2>/dev/null | grep -E -i '(mysql|postgres(ql)?)://[^:]+:[^@]+@' > /dev/null; then
    printf "${RED}X REJECT${NC}: connection string with password in %s\n" "$file"
    ERRORS=$((ERRORS + 1))
  fi

  # Generic secret patterns
  MATCHES="$(git show ":$file" 2>/dev/null | grep -E -i "$PATTERNS" || true)"
  if [ -n "$MATCHES" ]; then
    # Filter out documentation examples
    REAL_MATCHES="$(echo "$MATCHES" | grep -E -v '(example|placeholder|your[_-]?|xxx+|<[a-z]+>|\[[a-z]+\]|FILL_IN|TODO|REPLACE_ME)' || true)"
    if [ -n "$REAL_MATCHES" ]; then
      printf "${RED}X REJECT${NC}: secret pattern in %s:\n" "$file"
      echo "$REAL_MATCHES" | sed 's/^/    /' | head -3
      ERRORS=$((ERRORS + 1))
    fi
  fi

  # AWS-style access keys
  if git show ":$file" 2>/dev/null | grep -E 'AKIA[0-9A-Z]{16}' > /dev/null; then
    printf "${RED}X REJECT${NC}: AWS access key in %s\n" "$file"
    ERRORS=$((ERRORS + 1))
  fi

  # Bcrypt password hashes
  if git show ":$file" 2>/dev/null | grep -E '\$2[ayb]\$[0-9]{2}\$[A-Za-z0-9./]{53}' > /dev/null; then
    printf "${RED}X REJECT${NC}: bcrypt hash in %s\n" "$file"
    ERRORS=$((ERRORS + 1))
  fi

  # GitHub-style personal access tokens (ghp_, gho_, ghu_, ghs_, ghr_)
  if git show ":$file" 2>/dev/null | grep -E 'gh[pousr]_[A-Za-z0-9]{36,}' > /dev/null; then
    printf "${RED}X REJECT${NC}: GitHub token in %s\n" "$file"
    ERRORS=$((ERRORS + 1))
  fi

  # Slack tokens (xoxb-, xoxp-, xoxa-)
  if git show ":$file" 2>/dev/null | grep -E 'xox[abprs]-[A-Za-z0-9-]{20,}' > /dev/null; then
    printf "${RED}X REJECT${NC}: Slack token in %s\n" "$file"
    ERRORS=$((ERRORS + 1))
  fi
done <<EOF
$STAGED_FILES
EOF

# ============================================================
# RULE 3: frontmatter required on new wiki pages
# ============================================================
NEW_FILES="$(git diff --cached --name-only --diff-filter=A)"
while IFS= read -r file; do
  case "$file" in
    wiki/*.md)
      # Skip top-level structural files and proposed-adr drafts
      case "$file" in
        wiki/index.md|wiki/log.md|*/README.md|*/proposed-adr/*) continue ;;
      esac

      FIRST_LINE="$(git show ":$file" 2>/dev/null | head -1 || true)"
      if [ "$FIRST_LINE" != "---" ]; then
        printf "${YELLOW}! WARNING${NC}: %s has no frontmatter (first line is not '---')\n" "$file"
        WARNINGS=$((WARNINGS + 1))
      fi
      ;;
  esac
done <<EOF
$NEW_FILES
EOF

# ============================================================
# RULE 4: files outside the vault structure (with explicit allow-list)
# ============================================================
while IFS= read -r file; do
  case "$file" in
    wiki/*|raw/*|_templates/*|\
    CLAUDE.md|README.md|SETUP.md|CHANGELOG.md|ROADMAP.md|CONTRIBUTING.md|LICENSE|ATTRIBUTION.md|\
    .gitignore|.gitattributes|.server-id.example|\
    deploy/*|scripts/*|docs/*|\
    .git/*)
      ;;
    .server-id)
      printf "${RED}X REJECT${NC}: .server-id must not be committed (it's per-server)\n"
      ERRORS=$((ERRORS + 1))
      ;;
    *)
      printf "${YELLOW}! WARNING${NC}: file outside vault structure: %s\n" "$file"
      WARNINGS=$((WARNINGS + 1))
      ;;
  esac
done <<EOF
$STAGED_FILES
EOF

# ============================================================
# Result
# ============================================================
echo
if [ "$ERRORS" -gt 0 ]; then
  printf "${RED}Commit REJECTED${NC}: %d error(s), %d warning(s)\n" "$ERRORS" "$WARNINGS"
  printf "Review the issues above. To override (carefully): ${YELLOW}git commit --no-verify${NC}\n"
  exit 1
fi

if [ "$WARNINGS" -gt 0 ]; then
  printf "${YELLOW}Commit with %d warning(s)${NC} -- proceeding, but review.\n" "$WARNINGS"
fi

printf "${GREEN}Pre-commit OK${NC}\n"
exit 0
