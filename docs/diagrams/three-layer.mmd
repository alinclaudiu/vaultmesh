%% Three-layer architecture: raw / wiki / schema
%% Karpathy's contribution. VaultMesh keeps it intact.

flowchart TB
    subgraph Schema["CLAUDE.md (the schema)"]
        S1[Global rules]
        S2[Per-app rules<br/>dropped into each<br/>app's working dir]
    end

    subgraph Wiki["wiki/ (LLM-maintained)"]
        W1[apps/]
        W2[integrations/]
        W3[flows/]
        W4[infrastructure/]
        W5[shared/]
        W6[decisions/]
        W7[index.md<br/>regenerated by lint]
        W8[log.md<br/>append-only journal]
    end

    subgraph Raw["raw/ (immutable)"]
        R1[PDFs, articles,<br/>transcripts, exports]
    end

    Raw -. "ingest" .-> Wiki
    Schema -. "governs" .-> Wiki

    classDef schema fill:#1f6feb,stroke:#0d419d,color:#fff
    classDef wiki fill:#238636,stroke:#0f5223,color:#fff
    classDef raw fill:#bf8700,stroke:#7a5800,color:#fff
    class S1,S2 schema
    class W1,W2,W3,W4,W5,W6,W7,W8 wiki
    class R1 raw
